# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Image generation ──────────────────────────────────────────────────────────
IMAGE_API_KEY=...                # API key for image generation service

# ── Sponsor integrations ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...          # Brand research grounding

# ── Neural models ─────────────────────────────────────────────────────────────
