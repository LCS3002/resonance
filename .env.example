# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Sponsor integrations ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...          # Brand research grounding
OVERMIND_API_KEY=om-...          # Agent tracing + optimization loop

# ── Neural models (optional — falls back to mock scorer if not set) ───────────
# TRIBE_V2_CHECKPOINT=facebook/tribev2  # or local path to downloaded weights
# CUSTOM_CHECKPOINT=./runs/best.ckpt    # path to your trained BrainDecoder checkpoint

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
MCP_PORT=8001
HITL_THRESHOLD=0.45              # Variants below this score get flagged for human review
